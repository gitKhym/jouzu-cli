#[test]
fn gu_ender() {
    let verb = Verb {
        base_form: String::from("話す"),
        is_godan: true,
    };

    assert_eq!(verb.conjugate(vec![ConjugationKind::Negation]), "話さない",);

    assert_eq!(
        verb.conjugate(vec![ConjugationKind::Past, ConjugationKind::Negation]),
        "話さなくった"
    );
}
